pipeline {
    agent any

    // ─── ปรับค่าตรงนี้ตาม repo จริง ─────────────────────────────────────────
    environment {
        BRANCH_BACKEND = 'main'
        APP_DIR        = 'D:\\ICS-Projects\\apps\\food-ordering-service'
        APP_NAME       = 'food-ordering-service'
    }

    stages {

        // ─── Step 1: ดึงข้อมูลจาก GitHub ──────────────────────────────────────
        stage('Checkout') {
            steps {
                withVault(
                    configuration: [
                        vaultUrl: 'http://localhost:8200',
                        vaultCredentialId: 'vault-token'
                    ],
                    vaultSecrets: [[
                        path: 'secret/jenkins/github',
                        engineVersion: 2,
                        secretValues: [
                            [envVar: 'GITHUB_USER',  vaultKey: 'username'],
                            [envVar: 'GITHUB_TOKEN', vaultKey: 'token']
                        ]
                    ]]
                ) {
                    dir('src') {
                        bat """
                            git clone -b %BRANCH_BACKEND% ^
                                https://%GITHUB_USER%:%GITHUB_TOKEN%@github.com/nateesoft/food-ordering-service.git .
                        """
                    }
                }
            }
        }

        // ─── Step 2: Install Dependencies ─────────────────────────────────────
        stage('Install') {
            steps {
                dir('src') {
                    bat "npm ci"
                }
            }
        }

        // ─── Step 3: Build ─────────────────────────────────────────────────────
        stage('Build') {
            steps {
                dir('src') {
                    bat "npm run build"
                }
            }
        }

        // ─── Step 4: Deploy ────────────────────────────────────────────────────
        stage('Deploy Backend') {
            steps {
                // ลบ devDependencies ออกก่อน copy เพื่อลดขนาด node_modules
                dir('src') {
                    bat "npm prune --omit=dev"
                }

                // คัดลอกไฟล์ที่ build แล้วไปยัง APP_DIR (robocopy /XO = skip ไฟล์ที่ไม่เปลี่ยน)
                bat """
                    if not exist "%APP_DIR%" mkdir "%APP_DIR%"
                    robocopy src\\dist         "%APP_DIR%\\dist"         /E /XO /MT:8 /NJH /NJS
                    if %ERRORLEVEL% GTR 1 exit /b %ERRORLEVEL%
                    robocopy src\\node_modules "%APP_DIR%\\node_modules" /E /XO /MT:8 /NJH /NJS
                    if %ERRORLEVEL% GTR 1 exit /b %ERRORLEVEL%
                    robocopy src\\prisma       "%APP_DIR%\\prisma"       /E /XO /MT:8 /NJH /NJS
                    if %ERRORLEVEL% GTR 1 exit /b %ERRORLEVEL%
                    copy /Y src\\package.json  "%APP_DIR%\\package.json" || exit /b 1
                """
            }
        }

        // ─── Step 5: Write .env from Vault ────────────────────────────────────────
        stage('Write Env') {
            steps {
                withVault(
                    configuration: [
                        vaultUrl: 'http://localhost:8200',
                        vaultCredentialId: 'vault-token'
                    ],
                    vaultSecrets: [[
                        path: 'secret/food-ordering-service/app',
                        engineVersion: 2,
                        secretValues: [
                            [envVar: 'DATABASE_URL',        vaultKey: 'DATABASE_URL'],
                            [envVar: 'JWT_SECRET',          vaultKey: 'JWT_SECRET'],
                            [envVar: 'JWT_EXPIRES_IN',      vaultKey: 'JWT_EXPIRES_IN'],
                            [envVar: 'PORT',                vaultKey: 'PORT'],
                            [envVar: 'RABBITMQ_URL',        vaultKey: 'RABBITMQ_URL'],
                            [envVar: 'RABBITMQ_EXCHANGE',   vaultKey: 'RABBITMQ_EXCHANGE'],
                            [envVar: 'RABBITMQ_PREFETCH',   vaultKey: 'RABBITMQ_PREFETCH'],
                            [envVar: 'LOG_LEVEL',           vaultKey: 'LOG_LEVEL'],
                            [envVar: 'MINIO_ENDPOINT',      vaultKey: 'MINIO_ENDPOINT'],
                            [envVar: 'MINIO_ROOT_USER',     vaultKey: 'MINIO_ROOT_USER'],
                            [envVar: 'MINIO_ROOT_PASSWORD', vaultKey: 'MINIO_ROOT_PASSWORD'],
                            [envVar: 'MINIO_BUCKET',        vaultKey: 'MINIO_BUCKET']
                        ]
                    ]]
                ) {
                    bat """
                        (
                            echo DATABASE_URL=%DATABASE_URL%
                            echo JWT_SECRET=%JWT_SECRET%
                            echo JWT_EXPIRES_IN=%JWT_EXPIRES_IN%
                            echo PORT=%PORT%
                            echo RABBITMQ_URL=%RABBITMQ_URL%
                            echo RABBITMQ_EXCHANGE=%RABBITMQ_EXCHANGE%
                            echo RABBITMQ_PREFETCH=%RABBITMQ_PREFETCH%
                            echo LOG_LEVEL=%LOG_LEVEL%
                            echo MINIO_ENDPOINT=%MINIO_ENDPOINT%
                            echo MINIO_ROOT_USER=%MINIO_ROOT_USER%
                            echo MINIO_ROOT_PASSWORD=%MINIO_ROOT_PASSWORD%
                            echo MINIO_BUCKET=%MINIO_BUCKET%
                        ) > "%APP_DIR%\\.env"
                    """
                }
            }
        }

        // ─── Step 6: Migrate Database ──────────────────────────────────────────
        stage('Migrate Database') {
            steps {
                bat """
                    cd /d "%APP_DIR%"
                    npx prisma migrate deploy
                """
            }
        }

        // ─── Step 7: Start / Restart App ───────────────────────────────────────
        stage('Start App') {
            steps {
                bat """
                    pm2 describe %APP_NAME% >nul 2>&1 && (
                        pm2 restart %APP_NAME%
                    ) || (
                        pm2 start "%APP_DIR%\\dist\\main.js" ^
                            --name %APP_NAME% ^
                            --cwd "%APP_DIR%" ^
                            --log "%APP_DIR%\\logs\\app.log" ^
                            --env production
                    )
                    pm2 save
                """
                echo "Backend deployed → http://localhost/api"
            }
        }
    }

    post {
        success {
            echo "✅ Deployment successful → http://localhost/api"
        }
        failure {
            echo "❌ Pipeline failed — check the stage logs above."
        }
        always {
            deleteDir()
        }
    }
}
